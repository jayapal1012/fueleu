{
  "name": "fueleu",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\"",
    "test": "npm run test --workspace backend && npm run test --workspace frontend",
    "db:create": "npm run db:create --workspace backend",
    "db:schema": "npm run db:schema --workspace backend",
    "db:seed": "npm run db:seed --workspace backend",
    "db:reset": "npm run db:reset --workspace backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}

